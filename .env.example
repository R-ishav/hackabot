# Copy this file to .env and fill values for production
# Example MongoDB Atlas connection string:
# MONGO_URI="mongodb+srv://<username>:<password>@cluster0.xxxxxx.mongodb.net/campus-events?retryWrites=true&w=majority"
# JWT secret for signing QR tokens and other server secrets
# JWT_SECRET="replace_with_a_secure_random_string"
# Optional: override server port
# PORT=5000

# Google Maps API Key (for location search - get from https://console.cloud.google.com)
# Enable "Places API" and "Maps JavaScript API" in your Google Cloud project
# VITE_GOOGLE_MAPS_API_KEY="your_google_api_key_here"

# Example:
# MONGO_URI="mongodb+srv://alice:MyP@ssword@cluster0.abcd.mongodb.net/campus-events?retryWrites=true&w=majority"
# JWT_SECRET="s0m3_long_random_secret"
# VITE_GOOGLE_MAPS_API_KEY="AIzaSy..."
